{
  "expo": {
    "name": "Guard monitoring",
    "slug": "guardmonitoringapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/expo.icon/guard_monitoring_app.png",
    "scheme": "guardmonitoringapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon/guard_monitoring_app.png",
      "bundleIdentifier": "com.firdavsnurmatov.guardmonitoringapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/expo.icon/guard_monitoring_app.png",
        "backgroundImage": "./assets/expo.icon/guard_monitoring_app.png",
        "monochromeImage": "./assets/expo.icon/guard_monitoring_app.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "NFC",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.firdavsnurmatov.guardmonitoringapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/expo.icon/guard_monitoring_app.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/expo.icon/guard_monitoring_app.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "62681ba7-5a2a-40e4-8755-7cea9a889986"
      }
    }
  }
}
